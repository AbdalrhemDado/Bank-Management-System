import java.util.*;

public class Bank {

    private List<Customer> customers = new ArrayList<>();
    private Map<Integer, IAccount> accounts = new HashMap<>();

    private int nextCustomerId = 1;
    private int nextAccountNumber = 1000;

    private TransactionProcessor processor = new TransactionProcessor();

    public Customer registerCustomer(String name) {
        Customer customer = new Customer(nextCustomerId++, name);
        customers.add(customer);
        return customer;
    }

    public IAccount openAccount(Customer customer, String type) {
        IAccount account = AccountFactory.createAccount(type, nextAccountNumber);

        accounts.put(nextAccountNumber, account);
        customer.addAccount(account);
        nextAccountNumber++;

        return account;
    }

    public void performTransaction(int accountNumber, double amount, String type) {
        IAccount account = accounts.get(accountNumber);

        if (account == null) {
            System.out.println("Account not found.");
            return;
        }

        if ("deposit".equalsIgnoreCase(type)) {
            processor.executeDeposit(account, amount);
        } else if ("withdraw".equalsIgnoreCase(type)) {
            processor.executeWithdraw(account, amount);
        } else {
            System.out.println("Unknown transaction type.");
        }
    }

    public double getAccountBalance(int accountNumber) {
        IAccount account = accounts.get(accountNumber);
        return (account != null) ? account.getBalance() : -1;
    }
}
